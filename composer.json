{
    "name": "designbymalina/dbmframework",
    "description": "DbM Framework - Micro framework with optional CMS",
    "keywords": ["framework", "dbm-framework", "micro-framework", "php", "cms", "modular-monolith"],
    "homepage": "https://github.com/designbymalina/dbmframework",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Artur Malinowski",
            "homepage": "https://dbm.org.pl",
            "role": "developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "doctrine/dbal": "^4.3",
        "phpmailer/phpmailer": "^6.6",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "friendsofphp/php-cs-fixer": "^3.59",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Dbm\\": "application/",
            "Mod\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
